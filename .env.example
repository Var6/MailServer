# ============================================================
#  MailServer — Environment Configuration Template
#  Windows / single-server edition
#
#  Copy to .env and fill in your actual values.
#  Never commit .env to version control.
# ============================================================

# ── Domain ──────────────────────────────────────────────────
MAIL_DOMAIN=yourdomain.com
MAIL_HOSTNAME=mail.yourdomain.com

# ── Paths (Windows: use relative paths with forward slashes)
#    Named Docker volumes are used by default — you only need
#    these if you override volumes with bind-mounts.
MAIL_DATA_PATH=./data/mail
CERT_PATH=./data/certs

# ── MongoDB ─────────────────────────────────────────────────
MONGO_ROOT_USER=admin
MONGO_ROOT_PASSWORD=changeme
MONGO_APP_USER=mailserver
MONGO_APP_PASSWORD=changeme
# Standalone URI — no replicaSet param needed for single-server
MONGO_URI=mongodb://mailserver:changeme@mongodb:27017/mailserver?authSource=mailserver

# ── Redis ────────────────────────────────────────────────────
REDIS_PASSWORD=changeme

# ── JWT / Auth ───────────────────────────────────────────────
# Use at least 32 random characters for each secret.
# Generate with: openssl rand -hex 32
JWT_SECRET=changeme-at-least-32-chars-long
JWT_REFRESH_SECRET=changeme-at-least-32-chars-long

# Internal token shared between Dovecot and the API
# (never exposed externally — 16+ characters)
INTERNAL_AUTH_TOKEN=changeme-16chars

# ── Nextcloud ───────────────────────────────────────────────
NEXTCLOUD_ADMIN_USER=admin
NEXTCLOUD_ADMIN_PASSWORD=changeme
NEXTCLOUD_TRUSTED_DOMAINS=mail.yourdomain.com localhost

# ── Rspamd ───────────────────────────────────────────────────
RSPAMD_PASSWORD=changeme

# ── DKIM ─────────────────────────────────────────────────────
DKIM_SELECTOR=mail

# ── Mail client settings (filled automatically by the stack) ─
SMTP_HOST=
SMTP_PORT=587
IMAP_HOST=
IMAP_PORT=993

# ── App ──────────────────────────────────────────────────────
NODE_ENV=production
API_PORT=3000
CORS_ORIGIN=https://mail.yourdomain.com
SESSION_TTL_SECONDS=900
IMAP_POOL_IDLE_TTL_MS=600000

# ── SSL ──────────────────────────────────────────────────────
CERTBOT_EMAIL=admin@yourdomain.com

# ── Cloudflare Tunnel ────────────────────────────────────────
# Fill in after running scripts\setup-cloudflare.ps1
# Leave empty to disable the cloudflared service.
CLOUDFLARE_TUNNEL_TOKEN=

# ── Monitoring & Alerts (optional) ──────────────────────────
ALERT_EMAIL=admin@yourdomain.com
SLACK_WEBHOOK_URL=
MONITOR_INTERVAL=60

# ── Backup ───────────────────────────────────────────────────
BACKUP_DIR=./data/backups
