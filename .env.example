# ============================================================
#  MailServer — Environment Configuration Template
#  Copy to .env and fill in your actual values
# ============================================================

# --------------- Domain & Networking ----------------------
MAIL_DOMAIN=yourdomain.com
MAIL_HOSTNAME=mail.yourdomain.com
VIRTUAL_IP=192.168.1.100
PI_PRIMARY_IP=192.168.1.10
PI_SECONDARY_IP=192.168.1.11
PI_HOSTNAME=pi-primary                # Change to pi-secondary on 2nd Pi

# --------------- MariaDB / Galera -------------------------
MYSQL_ROOT_PASSWORD=CHANGE_ME_ROOT
MYSQL_DATABASE=mailserver
MYSQL_USER=mailserver
MYSQL_PASSWORD=CHANGE_ME_MAIL
DOVECOT_DB_USER=dovecot
DOVECOT_DB_PASS=CHANGE_ME_DOVECOT
NEXTCLOUD_DB_USER=nextcloud
NEXTCLOUD_DB_PASSWORD=CHANGE_ME_NC

# --------------- Redis ------------------------------------
REDIS_PASSWORD=CHANGE_ME_REDIS

# --------------- JWT / Auth --------------------------------
JWT_SECRET=CHANGE_ME_64_CHAR_RANDOM_STRING_HERE_PLEASE_USE_OPENSSL
JWT_REFRESH_SECRET=CHANGE_ME_ANOTHER_64_CHAR_RANDOM_STRING_HERE

# --------------- Nextcloud --------------------------------
NEXTCLOUD_ADMIN_USER=admin
NEXTCLOUD_ADMIN_PASSWORD=CHANGE_ME_NC_ADMIN
NEXTCLOUD_TRUSTED_DOMAINS=mail.yourdomain.com localhost 192.168.1.100

# --------------- Keepalived HA ----------------------------
KEEPALIVED_SECRET=CHANGE_ME_VRRP

# --------------- SSL / Certbot ----------------------------
CERTBOT_EMAIL=admin@yourdomain.com

# --------------- Rspamd -----------------------------------
RSPAMD_PASSWORD=CHANGE_ME_RSPAMD
RSPAMD_ENABLE_PASSWORD=CHANGE_ME_RSPAMD_ENABLE

# --------------- Monitoring & Alerts ----------------------
ALERT_EMAIL=admin@yourdomain.com
SLACK_WEBHOOK_URL=

# --------------- DKIM -------------------------------------
DKIM_SELECTOR=mail

# --------------- Backend API ------------------------------
NODE_ENV=production
API_PORT=3000
SESSION_TTL_SECONDS=900
IMAP_POOL_IDLE_TTL_MS=600000

# --------------- GlusterFS Paths (on host) ----------------
GLUSTER_MAIL_PATH=/gluster/mail
GLUSTER_NEXTCLOUD_PATH=/gluster/nextcloud
GLUSTER_CERTS_PATH=/gluster/certs
