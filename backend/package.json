{
  "name": "mailserver-api",
  "version": "1.0.0",
  "description": "REST API backend for MailServer webmail",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch --env-file=.env src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
