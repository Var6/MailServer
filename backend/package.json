    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@types/mailparser": "^3.4.6",
    "argon2": "^0.31.2",
    "axios": "^1.6.8",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "express": "^4.18.3",
    "express-rate-limit": "^7.2.0",
    "helmet": "^7.1.0",
    "imapflow": "^1.0.162",
    "jsonwebtoken": "^9.0.2",
    "mailparser": "^3.9.4",
    "mime-types": "^2.1.35",
    "mongoose": "^8.2.2",
    "nodemailer": "^6.9.12",
    "redis": "^4.6.13",
    "uuid": "^9.0.1",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/cookie-parser": "^1.4.7",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/mime-types": "^2.1.4",
    "@types/node": "^20.11.28",
    "@types/nodemailer": "^6.4.14",
    "@types/supertest": "^7.2.0",
    "@types/uuid": "^9.0.8",
    "@vitest/coverage-v8": "^4.1.0",
    "supertest": "^7.2.2",
    "tsx": "^4.21.0",
    "typescript": "^5.4.2",
    "vitest": "^4.1.0"
