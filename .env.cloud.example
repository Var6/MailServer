# ──────────────────────────────────────────────────────────────────────────────
# .env.cloud.example — Cloud deployment without Raspberry Pi or mail server
#
# Services used:
#   Frontend : Vercel (free)
#   Backend  : Render.com (free tier — https://dashboard.render.com)
#   Database : MongoDB Atlas (free M0 cluster — https://cloud.mongodb.com)
#
# Features that work in cloud mode:
#   ✅  Login / JWT auth
#   ✅  Super Admin → Tenant management
#   ✅  Company Admin → User management
#   ✅  Shared Team Calendar
#   ❌  Webmail inbox (needs Dovecot IMAP — not available without mail server)
#   ❌  Send email (needs Postfix SMTP)
#   ❌  Contacts / Files (needs Nextcloud)
#   ❌  Personal calendar (needs Nextcloud CalDAV)
# ──────────────────────────────────────────────────────────────────────────────

# ── Backend (set these in Render → Environment) ───────────────────────────────
NODE_ENV=production
PORT=3000

# MongoDB Atlas connection string
# Format: mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority
MONGO_URI=mongodb+srv://mailuser:yourpassword@cluster0.abcde.mongodb.net/mailserver?retryWrites=true&w=majority

# JWT — use long random strings (Render can auto-generate these)
JWT_SECRET=replace-with-at-least-32-random-characters
JWT_REFRESH_SECRET=replace-with-different-32-random-characters

# Your Vercel frontend URL (no trailing slash)
CORS_ORIGIN=https://your-app.vercel.app

MAIL_DOMAIN=yourdomain.com

# ── Frontend (set these in Vercel → Settings → Environment Variables) ─────────
# Points to your Render backend URL
VITE_API_URL=https://mailserver-api.onrender.com/

# ── Leave blank — not needed without a mail server ────────────────────────────
IMAP_HOST=
SMTP_HOST=
NEXTCLOUD_URL=
INTERNAL_AUTH_TOKEN=
